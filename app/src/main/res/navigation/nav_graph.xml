<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/inicialFragment">

    <fragment
        android:id="@+id/inicialFragment"
        android:name="com.example.myapplication.InicialFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_inicial">
        <action
            android:id="@+id/action_inicialFragment_to_game_graph"
            app:destination="@id/game_graph" />
    </fragment>

    <navigation
        android:id="@+id/game_graph"
        app:startDestination="@id/jogadorFragment">

        <fragment
            android:id="@+id/jogadorFragment"
            android:name="com.example.myapplication.JogadorFragment"
            android:label="@string/player_1"
            tools:layout="@layout/fragment_jogador" />

        <fragment
            android:id="@+id/resultadoFragment"
            android:name="com.example.myapplication.ResultadoFragment"
            android:label="@string/result"
            tools:layout="@layout/fragment_resultado" />
    </navigation>
</navigation>
